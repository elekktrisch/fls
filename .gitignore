# JetBrains workspace state (the .idea/.gitignore controls finer-grained excludes)
.idea/workspace.xml
.idea/shelf/
.idea/httpRequests/
.idea/queries/
.idea/dataSources/
.idea/dataSources.local.xml

# OS junk
.DS_Store
Thumbs.db

e2e/node_modules
e2e/playwright-report
e2e/screenshots

# Claude Code session state (per-process tasks, worktrees) — ignore the
# whole .claude/ tree by default, but track deliberate artifacts like skills.
.claude/*
!.claude/skills/
!.claude/agents/
next/server/build
next/server/.gradle
next/web/node_modules
next/web/dist
next/web/.angular