# JetBrains — ignore the whole .idea folder + every .iml. Files currently
# tracked under .idea/ stay tracked (gitignore doesn't retroactively apply);
# run `git rm --cached -r .idea/ '*.iml'` to untrack them if desired.
.idea/
*.iml

# OS junk
.DS_Store
Thumbs.db

e2e/node_modules
e2e/playwright-report
e2e/screenshots

# Claude Code session state (per-process tasks, worktrees) — ignore the
# whole .claude/ tree by default, but track deliberate artifacts like skills.
.claude/*
!.claude/skills/
!.claude/agents/
alpenflight/server/build
alpenflight/server/.gradle
alpenflight/web/node_modules
alpenflight/web/dist
alpenflight/web/.angular