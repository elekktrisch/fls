# next/ops/.env.example
# -----------------------------------------------------------------------------
# Copy to next/ops/.env (gitignored) only if you need to override a default.
# The committed docker-compose.yml ships sensible dev defaults — most
# contributors will never need a .env at all.
#
# When the prod overlay lands (S-041), this file grows to cover the secrets
# that are NOT defaulted in production. For now, dev-only.
# -----------------------------------------------------------------------------

# --- Postgres (profile: next) ---
# Defaults baked into docker-compose.yml: alpenflight / alpenflight / alpenflight.
# Override only if a host-Postgres collision forces a different port.
# POSTGRES_HOST_PORT=5432

# --- Keycloak (profile: next) ---
# Defaults: admin / admin, HTTP listener on 8080 inside the container,
# host-port 8090 (the AlpenFlight server occupies 8080).
# KEYCLOAK_HOST_PORT=8090
# KEYCLOAK_MGMT_HOST_PORT=9090

# --- Mailpit (default profile, shared with legacy) ---
# Defaults: SMTP 1025, Web UI 8025. Browse the dev inbox at
# http://localhost:8025 after the backend sends a mail.
# MAILPIT_SMTP_PORT=1025
# MAILPIT_WEB_PORT=8025
