{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:mock-auth": "ng serve --configuration mock-auth",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:mock-auth": "ng build --configuration mock-auth",
    "build:sandbox": "bash scripts/build-via-local-fs.sh production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --check \"src/**/*.{ts,html,css,json}\" \"e2e/**/*.{ts,json}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,html,css,json}\" \"e2e/**/*.{ts,json}\"",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:install": "playwright install --with-deps chromium",
    "generate-api": "orval --config ./orval.config.ts"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  },
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@fontsource/roboto": "^5.2.0",
    "@ngrx/operators": "^21.1.0",
    "@ngrx/signals": "^21.1.0",
    "angular-auth-oidc-client": "^21.0.2",
    "ng-zorro-antd": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "orval": "^8.10.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.0.8"
  }
}
