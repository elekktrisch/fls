{
  "openapi" : "3.1.0",
  "info" : {
    "title" : "AlpenFlight API",
    "description" : "Glider club operations platform. Source of truth for the SPA-generated TS client."
  },
  "servers" : [ {
    "url" : "http://localhost:8080"
  } ],
  "security" : [ {
    "bearerAuth" : [ ]
  } ],
  "tags" : [ {
    "name" : "Countries",
    "description" : "ISO-3166 country catalog."
  }, {
    "name" : "ClubStates",
    "description" : "Club lifecycle-state catalog."
  }, {
    "name" : "Clubs",
    "description" : "Clubs CRUD."
  } ],
  "paths" : {
    "/api/v1/clubs/{id}" : {
      "get" : {
        "tags" : [ "Clubs" ],
        "summary" : "Read a single club by id.",
        "operationId" : "getClub",
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "string",
            "example" : "clb-019e30c3-2c00-7001-8000-000000000001",
            "pattern" : "^clb-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "Club projection.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ClubResponse"
                }
              }
            }
          },
          "404" : {
            "description" : "No active club with that id.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ClubResponse"
                }
              }
            }
          }
        }
      },
      "put" : {
        "tags" : [ "Clubs" ],
        "summary" : "Update an existing club. `clubKey` is immutable post-create.",
        "operationId" : "updateClub",
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "string",
            "example" : "clb-019e30c3-2c00-7001-8000-000000000001",
            "pattern" : "^clb-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        } ],
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/ClubUpdateRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "200" : {
            "description" : "Updated; body is the new state.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ClubResponse"
                }
              }
            }
          },
          "404" : {
            "description" : "No active club with that id.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ClubResponse"
                }
              }
            }
          },
          "409" : {
            "description" : "Slug already in use by another club.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ClubResponse"
                }
              }
            }
          }
        }
      },
      "delete" : {
        "tags" : [ "Clubs" ],
        "summary" : "Soft-delete a club.",
        "operationId" : "deleteClub",
        "parameters" : [ {
          "name" : "id",
          "in" : "path",
          "required" : true,
          "schema" : {
            "type" : "string",
            "example" : "clb-019e30c3-2c00-7001-8000-000000000001",
            "pattern" : "^clb-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        } ],
        "responses" : {
          "204" : {
            "description" : "Deleted."
          },
          "404" : {
            "description" : "No active club with that id."
          }
        }
      }
    },
    "/api/v1/clubs" : {
      "get" : {
        "tags" : [ "Clubs" ],
        "summary" : "List all clubs (active, sorted by name).",
        "operationId" : "listClubs",
        "responses" : {
          "200" : {
            "description" : "Array of club projections.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/ClubResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post" : {
        "tags" : [ "Clubs" ],
        "summary" : "Create a new club. Slug must be unique.",
        "operationId" : "createClub",
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/ClubCreateRequest"
              }
            }
          },
          "required" : true
        },
        "responses" : {
          "201" : {
            "description" : "Created; body is the new club.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ClubResponse"
                }
              }
            }
          },
          "409" : {
            "description" : "Slug already in use.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/ClubResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/countries" : {
      "get" : {
        "tags" : [ "Countries" ],
        "summary" : "List all countries, alphabetical under de-CH ICU collation.",
        "operationId" : "listCountries",
        "responses" : {
          "200" : {
            "description" : "Array of country listitem projections.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/CountryResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/club-states" : {
      "get" : {
        "tags" : [ "ClubStates" ],
        "summary" : "List all club states, alphabetical under de-CH ICU collation.",
        "operationId" : "listClubStates",
        "responses" : {
          "200" : {
            "description" : "Array of club-state listitem projections.",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "array",
                  "items" : {
                    "$ref" : "#/components/schemas/ClubStateResponse"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components" : {
    "schemas" : {
      "ClubUpdateRequest" : {
        "type" : "object",
        "description" : "Payload to update a club. `clubKey` is immutable post-create.",
        "properties" : {
          "name" : {
            "type" : "string",
            "maxLength" : 100,
            "minLength" : 0
          },
          "slug" : {
            "type" : "string",
            "maxLength" : 64,
            "minLength" : 3,
            "pattern" : "^[a-z0-9-]+$"
          },
          "publicRegistrationEnabled" : {
            "type" : "boolean"
          },
          "countryId" : {
            "type" : "string",
            "format" : "uuid",
            "example" : "019e2e15-2c00-74be-8000-0000000004be",
            "pattern" : "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          },
          "clubStateId" : {
            "type" : "string",
            "format" : "uuid",
            "example" : "019e2e15-2c00-7bb8-8000-000000000bb8",
            "pattern" : "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        },
        "required" : [ "clubStateId", "countryId", "name", "slug" ]
      },
      "ClubResponse" : {
        "type" : "object",
        "description" : "Club projection returned to API consumers.",
        "properties" : {
          "id" : {
            "type" : "string",
            "example" : "clb-019e30c3-2c00-7001-8000-000000000001",
            "pattern" : "^clb-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          },
          "name" : {
            "type" : "string"
          },
          "slug" : {
            "type" : "string"
          },
          "clubKey" : {
            "type" : "string"
          },
          "publicRegistrationEnabled" : {
            "type" : "boolean"
          },
          "countryId" : {
            "type" : "string",
            "format" : "uuid",
            "example" : "019e2e15-2c00-74be-8000-0000000004be",
            "pattern" : "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          },
          "clubStateId" : {
            "type" : "string",
            "format" : "uuid",
            "example" : "019e2e15-2c00-7bb8-8000-000000000bb8",
            "pattern" : "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        },
        "required" : [ "clubStateId", "countryId" ]
      },
      "ClubCreateRequest" : {
        "type" : "object",
        "description" : "Payload to create a new club.",
        "properties" : {
          "name" : {
            "type" : "string",
            "maxLength" : 100,
            "minLength" : 0
          },
          "slug" : {
            "type" : "string",
            "maxLength" : 64,
            "minLength" : 3,
            "pattern" : "^[a-z0-9-]+$"
          },
          "clubKey" : {
            "type" : "string",
            "maxLength" : 10,
            "minLength" : 0
          },
          "publicRegistrationEnabled" : {
            "type" : "boolean"
          },
          "countryId" : {
            "type" : "string",
            "format" : "uuid",
            "example" : "019e2e15-2c00-74be-8000-0000000004be",
            "pattern" : "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          },
          "clubStateId" : {
            "type" : "string",
            "format" : "uuid",
            "example" : "019e2e15-2c00-7bb8-8000-000000000bb8",
            "pattern" : "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          }
        },
        "required" : [ "clubKey", "clubStateId", "countryId", "name", "slug" ]
      },
      "CountryResponse" : {
        "type" : "object",
        "description" : "Country listitem projection — dropdown fuel.",
        "properties" : {
          "id" : {
            "type" : "string",
            "format" : "uuid",
            "example" : "019e2e15-2c00-74be-8000-0000000004be",
            "pattern" : "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          },
          "iso2Code" : {
            "type" : "string"
          },
          "name" : {
            "type" : "string"
          }
        },
        "required" : [ "id", "iso2Code", "name" ]
      },
      "ClubStateResponse" : {
        "type" : "object",
        "description" : "ClubState listitem projection — dropdown fuel.",
        "properties" : {
          "id" : {
            "type" : "string",
            "format" : "uuid",
            "example" : "019e2e15-2c00-7bb8-8000-000000000bb8",
            "pattern" : "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
          },
          "code" : {
            "type" : "string"
          },
          "name" : {
            "type" : "string"
          }
        },
        "required" : [ "code", "id", "name" ]
      }
    },
    "securitySchemes" : {
      "bearerAuth" : {
        "type" : "http",
        "description" : "OIDC bearer token (Keycloak in dev, hosted IdP TBD in prod).",
        "scheme" : "bearer",
        "bearerFormat" : "JWT"
      }
    }
  }
}
